# Quay config.yaml
# Generated by rhis-builder-quay

SERVER_HOSTNAME: {{ quay_server_hostname }}{% if quay_preferred_url_scheme == 'http' and quay_http_port != 80 %}:{{ quay_http_port }}{% elif quay_preferred_url_scheme == 'https' and quay_https_port != 443 %}:{{ quay_https_port }}{% endif %}

SETUP_COMPLETE: true

DB_URI: postgresql://quay:{{ quay_pg_password }}@quay-postgres:5432/quay

DATABASE_SECRET_KEY: {{ quay_database_secret_key }}

SECRET_KEY: {{ quay_session_secret_key }}

BUILDLOGS_REDIS:
  host: quay-redis
  port: 6379

USER_EVENTS_REDIS:
  host: quay-redis
  port: 6379

DISTRIBUTED_STORAGE_CONFIG:
  default:
    - {{ quay_storage_backend }}
    - storage_path: {{ quay_storage_path }}
DISTRIBUTED_STORAGE_DEFAULT_LOCATIONS: []
DISTRIBUTED_STORAGE_PREFERENCE:
  - default

FEATURE_SECURITY_SCANNER: {{ quay_feature_security_scanner | lower }}
{% if quay_feature_security_scanner %}
SECURITY_SCANNER_V4_ENDPOINT: http://quay-clair:8080
SECURITY_SCANNER_V4_PSK: {{ quay_security_scanner_psk }}
{% endif %}

FEATURE_REPO_MIRROR: {{ quay_feature_repo_mirror | lower }}
{% if quay_feature_repo_mirror %}
REPO_MIRROR_INTERVAL: {{ quay_repo_mirror_interval }}
REPO_MIRROR_TLS_VERIFY: {{ quay_repo_mirror_tls_verify | lower }}
{% endif %}

FEATURE_MAILING: {{ quay_feature_mailing | lower }}

{% if quay_superusers is defined %}
SUPER_USERS:
{% for user in quay_superusers %}
  - {{ user }}
{% endfor %}
{% endif %}

PREFERRED_URL_SCHEME: {{ quay_preferred_url_scheme }}
{% if quay_external_tls_termination %}
EXTERNAL_TLS_TERMINATION: true
{% endif %}
