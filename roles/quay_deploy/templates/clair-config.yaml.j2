# Clair v4 config.yaml (combo mode)
# Generated by rhis-builder-quay

http_listen_addr: 0.0.0.0:8080
introspection_addr: 0.0.0.0:8089
log_level: info

indexer:
  connstring: host=quay-clair-postgres port=5432 dbname=clair user=clair password={{ quay_pg_password }} sslmode=disable
  scanlock_retry: 10
  layer_scan_concurrency: 5
  migrations: true

matcher:
  connstring: host=quay-clair-postgres port=5432 dbname=clair user=clair password={{ quay_pg_password }} sslmode=disable
  migrations: true

notifier:
  connstring: host=quay-clair-postgres port=5432 dbname=clair user=clair password={{ quay_pg_password }} sslmode=disable
  migrations: true
  poll_interval: 5m
  delivery_interval: 1m

auth:
  psk:
    key: {{ quay_security_scanner_psk }}
    iss:
      - quay
